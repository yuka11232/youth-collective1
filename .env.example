# Server
PORT=3000
NODE_ENV=development
PUBLIC_BASE_URL=http://localhost:3000
SESSION_SECRET=change-this-to-a-long-random-string
ALLOWED_ORIGIN=http://localhost:3000

# Optional Google login
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback

# Admin setup — generate a strong random value and keep it secret
# Used once to create the first admin account at /admin.html
ADMIN_SETUP_KEY=

# Optional email for password reset. If empty, dev mode returns the reset link in JSON.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM="Youth Collective <no-reply@youthcollective.local>"
